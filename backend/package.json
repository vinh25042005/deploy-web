{
  "name": "deploy-web-backend",
  "version": "1.0.0",
  "description": "E-commerce Backend API - Express + TypeScript + Prisma + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev --schema=../database/prisma/schema.prisma",
    "db:seed": "tsx ../database/seed.ts",
    "db:studio": "prisma studio --schema=../database/prisma/schema.prisma",
    "lint": "eslint src/",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ]
  },
  "prisma": {
    "schema": "../database/prisma/schema.prisma",
    "seed": "tsx ../database/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^10.6.0",
    "jest": "^30.2.0",
    "prisma": "^5.15.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.0"
  },
  "overrides": {
    "cross-spawn": "7.0.6",
    "minimatch": "9.0.9",
    "tar": "7.5.11",
    "glob": "11.1.0",
    "undici": "6.27.0"
  }
}
